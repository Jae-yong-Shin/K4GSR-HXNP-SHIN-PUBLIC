# =============================================================
#  K4GSR BL10 NanoProbe -- Deployment Configuration
#  All deployment scripts read this file for settings.
#  Edit this file to change deployment targets, paths, etc.
# =============================================================

# ---- GitHub Repository ----
GITHUB_REPO="https://github.com/Jae-yong-Shin/K4GSR-Beamline.git"
GITHUB_BRANCH="main"

# ---- Linux Server (Production) ----
SERVICE_USER="k4gsr"
INSTALL_DIR="/opt/k4gsr"
LOG_DIR="/var/log/k4gsr"
PYTHON_VERSION="3.11"

# ---- Network Ports ----
PORT_SERVER=8001        # Main WebSocket server
PORT_SIMULATION=8002    # Simulation server (xraylib/pyFAI)
PORT_EPICS_CA=5064      # EPICS Channel Access
PORT_EPICS_REPEATER=5065

# ---- vLLM Workstation (Remote NLP) ----
VLLM_HOST="<YOUR_CAMPUS_IP>"
VLLM_PORT=8000
VLLM_USER="science"

# ---- KOHZU Hardware ----
KOHZU_CONTROLLER_IP="<YOUR_DEVICE_IP>"
KOHZU_CONTROLLER_PORT=12321

# ---- XBPM2 (Sydor SI-DBPM-M403V + T4U Electrometer) ----
XBPM2_IP="<YOUR_DEVICE_IP>"
XBPM2_IOC_DIR="$HOME/synApps/support/quadEM-R9-4/iocBoot/iocT4UDirect_EM"
XBPM2_LOG="$HOME/xbpm2_ioc.log"

# ---- Fast Nano Scanner (SmarAct MCS2 + PicoScale) ----
# MCS2: piezo motion controller (3ch), custom SFP-100100-xy.30, 30um range
#   USB-connected to notebook → bridge server provides TCP access
# PicoScale V2: laser interferometer (encoder), Ethernet from VM1
MCS2_BRIDGE_HOST="<YOUR_DEVICE_IP>"
MCS2_BRIDGE_PORT=5555
PICOSCALE_LOCATOR="network:sn:<YOUR_PICOSCALE_SN>"
SMARACT_LIB_DIR="$HOME/picoscale_lib"
SMARACT_LOG="$HOME/smaract_ioc.log"

# ---- CA Port Assignment (Digital Twin Architecture) ----
# Each IOC uses a unique CA port — no UDP 5064 conflicts.
# soft_ioc always runs the FULL simulation model (ALL PVs, no exclusions).
# Real hardware IOCs run on dedicated ports; ca_bridge syncs RBV back to soft_ioc.
#
# Port map (add new HW IOCs here):
#   5064  soft_ioc  -- full beamline simulation (DCM/M1/M2/IVU/SAM/...)
#   5070  KOHZU     -- SAM: CX/CY/CZ real hardware
#   5071  (future)  -- PI PIMars (E-727 GCS2)
#   5072  XBPM2     -- Sydor T4U quadEM (Diamond BPM)
#   5073  SmarAct   -- Fast Nano Scanner (MCS2 + PicoScale)
#
SOFT_IOC_CA_PORT=5064
KOHZU_CA_PORT=5070
XBPM2_CA_PORT=5072
SMARACT_CA_PORT=5073
# HW ports listed first so caproto prefers real hardware for shared PV names.
# <YOUR_VM_IP> needed for multi-homed VM1 (caproto threading client UDP discovery).
EPICS_IOC_ADDR_LIST="127.0.0.1 <YOUR_VM_IP>"

# ---- Hardware Group Assignment ----
# PV groups served by real hardware IOCs (not soft_ioc).
# Used by: server.py --exclude-groups (to set hw_groups + CA ADDR_LIST)
# Note: soft_ioc.py serves ALL PVs (including SAM group).
#       KOHZU IOC shadows BL10:SAM:CX/CY/CZ via CA ADDR_LIST priority.
# Add new HW groups here as more hardware IOCs are connected.
SOFT_IOC_EXCLUDE_GROUPS="SAM XBPM2 SCAN"

# Groups that use non-standard PV names (not motor axes).
# PV Discovery will NOT probe BL10:{group}:{CX,CY,...} for these groups.
# Example: DBPM uses quadEM PVs (Current1:MeanValue_RBV, PosX:MeanValue_RBV)
#          instead of standard motor axes (X, Y, Z).
DISCOVERY_SKIP_GROUPS="XBPM2"

# ---- Server Startup Mode ----
# Options: standalone | full | hybrid
#   standalone: PVStore only (no EPICS, no Bluesky)
#   full:       soft_ioc + CA bridge + Bluesky
#   hybrid:     soft_ioc + real KOHZU IOC + CA bridge + Bluesky
SERVER_MODE="hybrid"

# ---- Optional Services ----
# Set to "yes" to auto-start, "no" to skip
ENABLE_SOFT_IOC="yes"
ENABLE_SIMULATION_SERVER="yes"
ENABLE_PTYCHO_SERVER="no"
