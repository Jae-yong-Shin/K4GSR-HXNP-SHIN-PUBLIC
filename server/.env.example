# NLP Engine: ollama | gemini | groq | claude | deepseek | openai | mistral | custom
NLP_ENGINE=groq

# Ollama (local LLM — free, offline)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:30b-a3b
# --- Model options (all via Ollama) ---
# qwen3:30b-a3b   18GB, MoE 30B/3.3B active, fits 8GB VRAM
# qwen3:32b        20GB, dense, best for fine-tuning (>=24GB VRAM)
# qwen3:235b-a22b 142GB, MoE, highest Qwen accuracy (>=96GB VRAM)
# glm-5:cloud      Ollama-hosted GLM-5 744B MoE (no local VRAM needed)
# glm-5:iq2_xxs   241GB local GGUF, requires >=256GB RAM

# Google Gemini (free tier)
GOOGLE_API_KEY=your-google-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# Groq (free tier — Llama 3.3 70B, very fast)
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# Anthropic Claude (paid)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
CLAUDE_MODEL=claude-sonnet-4-5-20250929

# DeepSeek (very cheap — $0.28/$0.42 per 1M tokens, good Korean)
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_MODEL=deepseek-chat

# OpenAI (reliable — GPT-4o-mini $0.15/$0.60 per 1M tokens)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# Mistral (cheapest — $0.06/$0.18 per 1M tokens)
MISTRAL_API_KEY=your-mistral-api-key-here
MISTRAL_MODEL=mistral-small-latest

# Custom OpenAI-compatible endpoint (Together AI, Fireworks, vLLM, etc.)
OPENAI_COMPAT_API_KEY=your-api-key-here
OPENAI_COMPAT_BASE_URL=https://api.together.xyz/v1
OPENAI_COMPAT_MODEL=deepseek-ai/DeepSeek-V3
